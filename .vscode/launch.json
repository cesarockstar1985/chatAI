            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "runtimeExecutable": "/bin/node",
            "env": {
                "PATH": "/usr/bin:/home/cperalta/.local/bin:/usr/local/bin:/bin:/usr/local/sbin"
            }
        }
    ]
}